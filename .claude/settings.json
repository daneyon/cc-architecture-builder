{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "opus",
  "agent": "orchestrator",
  "effortLevel": "high",

  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Bash(git *)",
      "Bash(ls *)",
      "Bash(mkdir *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(npm publish *)",
      "Bash(git push --force*)",
      "Bash(git push * --force*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(curl * | sh*)",
      "Bash(curl * | bash*)",
      "Bash(eval *)",
      "Edit(**/.env*)",
      "Write(**/.env*)",
      "Edit(**/.ssh/*)",
      "Write(**/.ssh/*)",
      "Edit(**/.aws/*)",
      "Write(**/.aws/*)"
    ]
  }
}
