{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "opus",
  "agent": "orchestrator",
  "effortLevel": "high",

  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Bash(git *)",
      "Bash(ls *)",
      "Bash(mkdir *)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(sudo *)",
      "Bash(npm publish *)"
    ]
  }
}
